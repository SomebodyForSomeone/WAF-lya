{
  "waf_port": ":8000",
  "server_address": "http://localhost:8081",

  "middleware_chain": [
    "context",
    "rate_limit",
    "signature"
  ],

  "rate_limit": {
    "limit": 5,
    "burst": 20,
    "ban_seconds": 30,
    "multiplier": 2.0,
    "violation_reset_hours": 24
  },

  "signature": {
    "log_matches": true
  },

  "context": {
    "window_seconds": 60,
    "threshold": 20,
    "ban_seconds": 300,
    "multiplier": 2.0,
    "violation_reset_hours": 24
  },
  "path_traversal_patterns_source": {
    "source_type": "url",
    "source": "https://example.com/patterns.txt",
    "format": "txt",
    "enable": false
  },
  "path_traversal_patterns_source_file": {
    "source_type": "file",
    "source": "patterns/path_traversal.txt",
    "format": "txt"
  }
}
